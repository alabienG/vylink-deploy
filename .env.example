# ── Fichier d'exemple — copiez en .env et adaptez les valeurs ──────────────
# cp .env.example .env

# ── OBLIGATOIRE ──────────────────────────────────────────────────────────────

# Username ou organisation GitHub qui héberge les images GHCR
GITHUB_OWNER=alabienG

# Mot de passe PostgreSQL (utilisez un mot de passe fort !)
POSTGRES_PASSWORD=changez_moi_mot_de_passe_fort

# Secret JWT — minimum 256 bits (64 caractères hex)
# Générez-en un avec : openssl rand -hex 32
JWT_SECRET=changez_moi_minimum_256_bits_de_long_string_aleatoire!!

# ── VERSIONS ─────────────────────────────────────────────────────────────────

# Version des images à utiliser (ex: latest, v1.0.0, v1.2.3)
# Laissez "latest" pour toujours avoir la dernière version stable
BACKEND_VERSION=latest
FRONTEND_VERSION=latest

# ── OPTIONNEL ────────────────────────────────────────────────────────────────

# Base de données
POSTGRES_DB=vylink
POSTGRES_USER=vylink

# Port HTTP du frontend sur le serveur (défaut: 80)
# HTTP_PORT=80

# Origines CORS autorisées (URLs depuis lesquelles le frontend accède au backend)
# Exemples : http://mon-serveur.com  ou  https://vylink.mondomaine.fr
CORS_ALLOWED_ORIGINS=http://localhost

# Niveau de log du backend (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO


